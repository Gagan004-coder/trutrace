# TiDB Cloud Connection
TIDB_HOST=your-tidb-host.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-tidb-user
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=trutrace

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server
PORT=3001

# Frontend URL (used for CORS in dev)
FRONTEND_URL=https://your-render-frontend-url.onrender.com

# Email (for password reset) — uses Resend HTTP API (works on all hosting)
# Sign up free at https://resend.com → API Keys → Create Key
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address (must be a verified domain on Resend,
# or use onboarding@resend.dev for testing)
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=TruTrace Security
