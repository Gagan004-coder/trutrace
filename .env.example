# TiDB Cloud Connection
TIDB_HOST=your-tidb-host.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-tidb-user
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=trutrace

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server
PORT=3001

# Frontend URL (used for CORS in dev)
FRONTEND_URL=https://your-render-frontend-url.onrender.com

# SMTP Email (for password reset emails)
# Gmail: use an App Password (not your real password)
#   → https://myaccount.google.com/apppasswords
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=<your-api-key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM_NAME=TruTrace Security
